## 3. MAIN LOOP LOGIC
 
```
FUNCTION ANALYZE_CONTEXT() → ContextData {
    // ═══════════════════════════════════════════════════════════
    // SENSOR FUSION - Combine all inputs into context
    // ═══════════════════════════════════════════════════════════
    
    CREATE contextData structure
    
    // ──────────────────────────────────────────────────────────
    // LIGHT SENSOR ANALYSIS
    // ──────────────────────────────────────────────────────────
    contextData.lightLevel = LDR.getLevel()
    contextData.isDark = LDR.isCurrentlyDark()
    contextData.isBright = LDR.isBright()
    contextData.lightJustChanged = LDR.hasSuddenChange()
    contextData.wentDarkSuddenly = LDR.justWentDark() AND 
                                    LDR.hasSuddenChange()
    
    // ──────────────────────────────────────────────────────────
    // TOUCH SENSOR ANALYSIS
    // ──────────────────────────────────────────────────────────
    headTouch = TouchSensor.getData(TOUCH_HEAD)
    bodyTouch = TouchSensor.getData(TOUCH_BODY)
    backTouch = TouchSensor.getData(TOUCH_BACK)
    
    contextData.anyTouched = headTouch.isTouched OR 
                              bodyTouch.isTouched OR 
                              backTouch.isTouched
    
    contextData.allTouched = headTouch.isTouched AND 
                              bodyTouch.isTouched AND 
                              backTouch.isTouched
    
    // Detect specific patterns
    contextData.headPetDetected = headTouch.isHolding AND 
                                   NOT AccelSensor.isMoving()
    
    contextData.hugDetected = headTouch.isHolding AND 
                               bodyTouch.isHolding
    
    contextData.tickleDetected = backTouch.isTouched AND 
                                  backTouch.tapCount >= 3
    
    // Count recent touches for play mode detection
    recentTouchCount = COUNT_RECENT_TOUCHES(last 2 seconds)
    contextData.playModeDetected = recentTouchCount >= 5 AND 
                                    AccelSensor.isMoving()
    
    // Excessive touching
    contextData.excessiveTouch = COUNT_TOUCHES(last 10 seconds) > 20
    
    // Special pattern detection
    pattern = TouchSensor.detectPattern()
    contextData.wifiSetupRequested = (pattern == PATTERN_WIFI_SETUP)
    
    // ──────────────────────────────────────────────────────────
    // ACCELEROMETER ANALYSIS
    // ──────────────────────────────────────────────────────────
    motionType = AccelSensor.getMotionType()
    
    contextData.isStill = (motionType == MOTION_STILL)
    contextData.isMoving = (motionType == MOTION_MOVING)
    contextData.isBeingPickedUp = (motionType == MOTION_PICKED_UP)
    contextData.isBeingShaken = (motionType == MOTION_SHAKING)
    contextData.isDropped = (motionType == MOTION_DROPPED)
    contextData.isTilted = (motionType == MOTION_TILTED)
    
    contextData.upsideDown = AccelSensor.isCurrentlyUpsideDown()
    IF contextData.upsideDown:
        IF NOT wasUpsideDown:
            upsideDownStartTime = now()
        contextData.upsideDownDuration = now() - upsideDownStartTime
    ELSE:
        upsideDownStartTime = 0
        contextData.upsideDownDuration = 0
    
    contextData.stillDuration = AccelSensor.getTimeSinceMovement()
    contextData.gentleRocking = DETECT_GENTLE_ROCKING()
    
    // ──────────────────────────────────────────────────────────
    // MICROPHONE ANALYSIS
    // ──────────────────────────────────────────────────────────
    soundType = MicSensor.getSoundType()
    
    contextData.soundLevel = MicSensor.getLevel()
    contextData.isQuiet = MicSensor.isQuiet()
    contextData.isLoud = MicSensor.isLoud()
    contextData.suddenLoudNoise = MicSensor.isSuddenLoud()
    
    contextData.voiceDetected = (soundType == SOUND_VOICE)
    contextData.musicDetected = (soundType == SOUND_MUSIC)
    contextData.machineNoiseDetected = (soundType == SOUND_MACHINE)
    
    contextData.voiceConfidence = MicSensor.getVoiceConfidence()
    contextData.musicConfidence = MicSensor.getMusicConfidence()
    
    // Continuous noise annoyance
    IF contextData.isLoud:
        IF NOT wasLoud:
            loudNoiseStartTime = now()
        loudNoiseDuration = now() - loudNoiseStartTime
        contextData.excessiveNoise = loudNoiseDuration > 10000  // 10s
    ELSE:
        loudNoiseStartTime = 0
        contextData.excessiveNoise = FALSE
    
    // ──────────────────────────────────────────────────────────
    // TIMING ANALYSIS
    // ──────────────────────────────────────────────────────────
    IF contextData.anyTouched OR contextData.isMoving OR NOT contextData.isQuiet:
        lastInteractionTime = now()
    
    contextData.timeSinceInteraction = now() - lastInteractionTime
    contextData.isIdle = contextData.timeSinceInteraction > IDLE_TIMEOUT
    
    // ──────────────────────────────────────────────────────────
    // COMBINED SITUATION DETECTION
    // ──────────────────────────────────────────────────────────
    
    // Good Morning: Dark→Bright + Picked Up
    contextData.goodMorningDetected = LDR.justWentBright() AND 
                                       contextData.isBeingPickedUp
    
    // Bedtime: Dark + Quiet + Gentle Rocking
    contextData.bedtimeDetected = contextData.isDark AND 
                                   contextData.isQuiet AND 
                                   contextData.gentleRocking
    
    // Comfort after scare: All held after scared state
    contextData.comfortDetected = contextData.allTouched AND 
                                   (currentEmotion == SCARED)
    
    // Attention seeking trigger
    contextData.shouldSeekAttention = contextData.timeSinceInteraction > 180000 AND
                                       NOT contextData.isDark
    
    RETURN contextData
}
 
FUNCTION EXECUTE_STATE_BEHAVIOR(emotion) {
    // ═══════════════════════════════════════════════════════════
    // STATE-SPECIFIC BEHAVIORS
    // ═══════════════════════════════════════════════════════════
    
    SWITCH emotion:
        
        CASE HAPPY:
            Display.setEmotion(HAPPY)
            
            // Respond to interactions
            IF headTouch.justPressed:
                Buzzer.acknowledge()
                lastInteractionTime = now()
            
            IF bodyTouch.isDoubleTap:
                Buzzer.giggle()
                Display.showHearts()
                delay(1000)
            
            IF backTouch.justPressed:
                Buzzer.beep()
            
            // Random happy behaviors
            IF random(0, 1000) < 5:  // 0.5% chance per loop
                Buzzer.playMelodyFor(HAPPY)
        
        CASE EXCITED:
            Display.setEmotion(EXCITED)
            
            // High energy responses
            IF anyTouchDetected:
                Buzzer.playMelodyFor(EXCITED)
            
            // More animated display
            Display.setAnimationSpeed(FAST)
        
        CASE CURIOUS:
            Display.setEmotion(CURIOUS)
            
            // Track sound source (simulated - pupils move)
            IF voiceDetected:
                Display.lookTowards(FRONT)
            
            IF musicDetected:
                Display.bobHead()  // Rhythmic movement
            
            // Questioning sound
            IF lightJustChanged:
                Buzzer.playMelodyFor(CURIOUS)
        
        CASE BORED:
            Display.setEmotion(BORED)
            
            // Attention seeking (every 30s when bored)
            IF boredAttentionTimer.isReady():
                Buzzer.alert()
                Display.lookAround()
                boredAttentionTimer.setInterval(30000)
                boredAttentionTimer.reset()
        
        CASE SLEEPY:
            Display.setEmotion(SLEEPY)
            
            // Yawn periodically
            IF sleepyYawnTimer.isReady():
                Buzzer.yawn()
                Display.yawnAnimation()
                sleepyYawnTimer.setInterval(random(5000, 15000))
                sleepyYawnTimer.reset()
            
            // Prepare for deep sleep
            IF energyLevel < 20 AND timeSinceInteraction > 600000:
                shouldEnterDeepSleep = TRUE
        
        CASE SCARED:
            Display.setEmotion(SCARED)
            
            // Alert sounds
            IF justEnteredState:
                Buzzer.playMelodyFor(SCARED)
            
            // Wide-eyed, looking around frantically
            Display.setAnimationSpeed(FAST)
            Display.lookAround()
            
            // Calm down if comforted
            IF headPetDetected:
                scaredRecoveryProgress += 10
                IF scaredRecoveryProgress >= 100:
                    // Will transition to HAPPY next cycle
                    Buzzer.purr()
        
        CASE DIZZY:
            Display.setEmotion(DIZZY)
            
            IF justEnteredState:
                Buzzer.playMelodyFor(DIZZY)
            
            // Swirly eyes animation handled by Display class
            
            // Recovery when still
            IF isStill:
                dizzyRecoveryTime++
                IF dizzyRecoveryTime > 50:  // 5 seconds at 100ms updates
                    // Will transition to HAPPY
                    dizzyRecoveryTime = 0
        
        CASE ANNOYED:
            Display.setEmotion(ANNOYED)
            
            IF justEnteredState:
                Buzzer.playMelodyFor(ANNOYED)
            
            // Grumpy, less responsive
            // Ignore some interactions
            IF anyTouchDetected AND random(0, 100) < 70:
                // 70% chance to ignore
                RETURN
}
 
FUNCTION UPDATE_ENERGY_SYSTEM() {
    // ═══════════════════════════════════════════════════════════
    // ENERGY MANAGEMENT
    // ═══════════════════════════════════════════════════════════
    
    IF energyDrainTimer.isReady():  // Every minute
        IF currentEmotion != SLEEPY:
            energyLevel -= ENERGY_DRAIN_RATE
            
            // Extra drain when very active
            IF currentEmotion == EXCITED:
                energyLevel -= 2
            
            energyLevel = constrain(energyLevel, 0, ENERGY_MAX)
        ELSE:
            // Restore energy when sleeping
            energyLevel += 5
            energyLevel = constrain(energyLevel, 0, ENERGY_MAX)
        
        energyDrainTimer.reset()
    
    // Influence state transitions
    IF energyLevel < 30 AND currentEmotion != SCARED:
        emotionBias = SLEEPY  // Bias toward sleepy state
}
 
