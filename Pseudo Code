LOOP() {
    // ═══════════════════════════════════════════════════════════
    // MAIN EXECUTION LOOP (Non-Blocking)
    // ═══════════════════════════════════════════════════════════
    
    1. UPDATE ALL SENSORS (every 50ms)
       ┌─────────────────────────────────────────────────┐
       │ IF sensorUpdateTimer.isReady():                 │
       │   ├─ LDR.update()                               │
       │   ├─ TouchSensor.update()                       │
       │   ├─ AccelSensor.update()                       │
       │   │   └─ Pass movement state to TouchSensor     │
       │   │       (for hold vs intentional touch)       │
       │   └─ MicSensor.update()                         │
       └─────────────────────────────────────────────────┘
    
    2. CHECK FOR PRIORITY EVENTS (Immediate Response)
       ┌─────────────────────────────────────────────────┐
       │ // These override normal behavior                │
       │ IF AccelSensor.isDropping():                     │
       │   └─ EMERGENCY_RESPONSE("DROPPED")              │
       │                                                   │
       │ IF MicSensor.isSuddenLoud():                     │
       │   └─ EMERGENCY_RESPONSE("STARTLED")             │
       │                                                   │
       │ IF AccelSensor.isUpsideDown() for > 3s:         │
       │   └─ EMERGENCY_RESPONSE("HELP")                 │
       │                                                   │
       │ IF TouchPattern == WIFI_SETUP:                   │
       │   └─ WIFI_SETUP_SEQUENCE()                      │
       └─────────────────────────────────────────────────┘
    
    3. PROCESS SENSOR FUSION (every 100ms)
       ┌─────────────────────────────────────────────────┐
       │ IF behaviorTimer.isReady():                     │
       │   └─ contextData = ANALYZE_CONTEXT()            │
       │       ├─ Combine all sensor data                │
       │       ├─ Detect interaction patterns            │
       │       ├─ Calculate situation score              │
       │       └─ Return context structure               │
       └─────────────────────────────────────────────────┘
    
    4. UPDATE EMOTION STATE MACHINE
       ┌─────────────────────────────────────────────────┐
       │ newEmotion = EVALUATE_EMOTION(contextData)      │
       │                                                   │
       │ IF newEmotion != currentEmotion:                 │
       │   IF stateTransitionCooldown.expired():          │
       │     ├─ previousEmotion = currentEmotion         │
       │     ├─ currentEmotion = newEmotion              │
       │     ├─ ON_STATE_CHANGE()                        │
       │     └─ stateTransitionCooldown.reset()          │
       └─────────────────────────────────────────────────┘
    
