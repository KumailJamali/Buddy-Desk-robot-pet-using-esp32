FUNCTION WAKE_UP_FROM_DEEP_SLEEP() {
    // ═══════════════════════════════════════════════════════════
    // CALLED AUTOMATICALLY ON WAKE (in setup())
    // ═══════════════════════════════════════════════════════════
    
    STEP 1: Determine Wake Cause
    ┌───────────────────────────────────────────────────────────┐
    │ esp_sleep_wakeup_cause_t wakeup_reason                    │
    │ wakeup_reason = esp_sleep_get_wakeup_cause()             │
    │                                                            │
    │ SWITCH wakeup_reason:                                     │
    │   CASE ESP_SLEEP_WAKEUP_TOUCHPAD:                        │
    │     wakeReason = "Touch detected"                         │
    │     wakeAnimation = HAPPY_WAKE                            │
    │                                                            │
    │   CASE ESP_SLEEP_WAKEUP_EXT0:                            │
    │     wakeReason = "Movement detected"                      │
    │     wakeAnimation = SURPRISED_WAKE                        │
    │                                                            │
    │   CASE ESP_SLEEP_WAKEUP_TIMER:                           │
    │     wakeReason = "Timer wake"                             │
    │     wakeAnimation = SLEEPY_WAKE                           │
    │                                                            │
    │   DEFAULT:                                                 │
    │     wakeReason = "Power on"                               │
    │     wakeAnimation = STARTUP                                │
    └───────────────────────────────────────────────────────────┘
    
    STEP 2: Restore State
    ┌───────────────────────────────────────────────────────────┐
    │ Preferences.begin("robot", true)                          │
    │ lastEmotion = Preferences.getInt("lastEmotion", HAPPY)    │
    │ energyLevel = Preferences.getInt("energyLevel", 100)      │
    │ sleepTime = Preferences.getULong("sleepTime", 0)         │
    │ Preferences.end()                                          │
    │                                                            │
    │ // Calculate sleep duration                               │
    │ sleepDuration = (millis() - sleepTime) / 1000 // seconds │
    │                                                            │
    │ // Restore energy based on sleep duration                 │
    │ energyRestored = sleepDuration / 60  // 1 per minute     │
    │ energyLevel += energyRestored                             │
    │ energyLevel = constrain(energyLevel, 0, 100)             │
    └───────────────────────────────────────────────────────────┘
    
    STEP 3: Wake-Up Sequence
    ┌───────────────────────────────────────────────────────────┐
    │ 1. Display.powerOn()                                      │
    │ 2. Display.begin()                                        │
    │                                                            │
    │ 3. Play wake animation based on wake reason:              │
    │    IF wakeAnimation == HAPPY_WAKE:                        │
    │      Display.stretchAnimation()                           │
    │      Buzzer.startupSound()                                │
    │      currentEmotion = HAPPY                                │
    │                                                            │
    │    ELSE IF wakeAnimation == SURPRISED_WAKE:               │
    │      Display.wideEyes()                                   │
    │      Buzzer.questionTone()                                │
    │      currentEmotion = CURIOUS                             │
    │                                                            │
    │    ELSE IF wakeAnimation == SLEEPY_WAKE:                  │
    │      Display.slowWake()                                   │
    │      Buzzer.yawn()                                        │
    │      currentEmotion = SLEEPY                              │
    │      // May go back to sleep if conditions still met      │
    └───────────────────────────────────────────────────────────┘
    
    STEP 4: Resume Normal Operation
    ┌───────────────────────────────────────────────────────────┐
    │ // Re-initialize sensors                                  │
    │ AccelSensor.begin()                                       │
    │ MicSensor.begin()                                         │
    │                                                            │
    │ // Reconnect WiFi if was previously connected             │
    │ IF WiFi credentials saved:                                │
    │   WiFiManager.connectToWiFi()                            │
    │                                                            │
    │ // Reset interaction timer                                │
    │ lastInteractionTime = millis()                            │
    │                                                            │
    │ // Continue with main loop                                │
    │ Serial.println("☀️ Awake and ready!")                    │
    └───────────────────────────────────────────────────────────┘
}
 
