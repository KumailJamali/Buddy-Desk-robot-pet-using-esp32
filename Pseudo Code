FUNCTION shouldEnterDeepSleep() → BOOLEAN {
    // ═══════════════════════════════════════════════════════════
    // CRITERIA FOR DEEP SLEEP
    // ═══════════════════════════════════════════════════════════
    
    CHECK 1: Time-Based
    ┌───────────────────────────────────────────────────────────┐
    │ IF timeSinceInteraction > 30 minutes:                     │
    │   criteriaCount++                                          │
    └───────────────────────────────────────────────────────────┘
    
    CHECK 2: Environment-Based
    ┌───────────────────────────────────────────────────────────┐
    │ IF LDR.isCurrentlyDark() for > 5 minutes:                │
    │   criteriaCount++                                          │
    └───────────────────────────────────────────────────────────┘
    
    CHECK 3: Energy-Based
    ┌───────────────────────────────────────────────────────────┐
    │ IF energyLevel < 20:                                      │
    │   criteriaCount++                                          │
    └───────────────────────────────────────────────────────────┘
    
    CHECK 4: State-Based
    ┌───────────────────────────────────────────────────────────┐
    │ IF currentEmotion == SLEEPY:                              │
    │   criteriaCount++                                          │
    └───────────────────────────────────────────────────────────┘
    
    CHECK 5: Motion-Based
    ┌───────────────────────────────────────────────────────────┐
    │ IF AccelSensor.getTimeSinceMovement() > 20 minutes:      │
    │   criteriaCount++                                          │
    └───────────────────────────────────────────────────────────┘
    
    DECISION:
    ┌───────────────────────────────────────────────────────────┐
    │ IF criteriaCount >= 3:                                    │
    │   RETURN TRUE  // Enter deep sleep                        │
    │ ELSE:                                                      │
    │   RETURN FALSE // Stay awake                              │
    └───────────────────────────────────────────────────────────┘
}
 
