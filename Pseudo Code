FUNCTION EVALUATE_EMOTION(contextData) {
    // ═══════════════════════════════════════════════════════════
    // PRIORITY LEVELS FOR STATE TRANSITIONS
    // ═══════════════════════════════════════════════════════════
    
    PRIORITY 1: Emergency States (Override everything)
    ┌─────────────────────────────────────────────────────────────┐
    │ IF contextData.isDropped:                                   │
    │   └─ RETURN SCARED                                          │
    │                                                              │
    │ IF contextData.suddenLoudNoise:                             │
    │   └─ RETURN SCARED                                          │
    │                                                              │
    │ IF contextData.upsideDownDuration > 3000ms:                 │
    │   └─ RETURN SCARED                                          │
    │                                                              │
    │ IF contextData.shakeIntensity > HIGH:                       │
    │   └─ RETURN DIZZY                                           │
    └─────────────────────────────────────────────────────────────┘
    
    PRIORITY 2: Special Interaction States
    ┌─────────────────────────────────────────────────────────────┐
    │ IF contextData.playModeDetected:                            │
    │   // Rapid touches + movement + sounds                      │
    │   └─ RETURN EXCITED                                         │
    │                                                              │
    │ IF contextData.allSensorsHeld AND currentState == SCARED:   │
    │   // Comfort after scare                                    │
    │   └─ RETURN HAPPY                                           │
    │                                                              │
    │ IF contextData.excessiveNoise OR contextData.excessiveTouch:│
    │   └─ RETURN ANNOYED                                         │
    └─────────────────────────────────────────────────────────────┘
    
    PRIORITY 3: Environmental States
    ┌─────────────────────────────────────────────────────────────┐
    │ IF contextData.voiceDetected:                               │
    │   └─ RETURN CURIOUS                                         │
    │                                                              │
    │ IF contextData.musicDetected:                               │
    │   └─ RETURN HAPPY or EXCITED (based on current)            │
    │                                                              │
    │ IF contextData.lightJustChangedSignificantly:               │
    │   └─ RETURN CURIOUS                                         │
    └─────────────────────────────────────────────────────────────┘
    
    PRIORITY 4: Time-Based States
    ┌─────────────────────────────────────────────────────────────┐
    │ IF contextData.timeSinceInteraction > 10 minutes:           │
    │   IF energyLevel < 30:                                      │
    │     └─ RETURN SLEEPY                                        │
    │   ELSE:                                                      │
    │     └─ Keep current state                                   │
    │                                                              │
    │ IF contextData.timeSinceInteraction > 3 minutes:            │
    │   └─ RETURN BORED                                           │
    │                                                              │
    │ IF currentState == BORED:                                   │
    │   IF energyLevel < 50:                                      │
    │     └─ TRANSITION TO SLEEPY                                 │
    └─────────────────────────────────────────────────────────────┘
    
    PRIORITY 5: Comfort/Return to Normal
    ┌─────────────────────────────────────────────────────────────┐
    │ IF currentState == SCARED:                                  │
    │   IF contextData.headPetDetected OR contextData.isQuiet:    │
    │     └─ RETURN HAPPY                                         │
    │                                                              │
    │ IF currentState == DIZZY:                                   │
    │   IF contextData.stillDuration > 3000ms:                    │
    │     └─ RETURN HAPPY                                         │
    │                                                              │
    │ IF currentState == ANNOYED:                                 │
    │   IF contextData.timeSinceAnnoyance > 5000ms:               │
    │     └─ RETURN HAPPY                                         │
    └─────────────────────────────────────────────────────────────┘
    
    PRIORITY 6: Default (Stay in current state)
    ┌─────────────────────────────────────────────────────────────┐
    │ RETURN currentEmotion                                       │
    └─────────────────────────────────────────────────────────────┘
}
 
