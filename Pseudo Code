// State variables
EmotionState currentEmotion = HAPPY;
EmotionState previousEmotion = HAPPY;
int energyLevel = 100;
unsigned long lastInteractionTime = 0;
bool justEnteredState = false;
bool shouldEnterDeepSleep = false;
 
void setup() {
    Serial.begin(115200);
    Serial.println("🤖 ESP32 Desk Robot Starting...");
    
    // Check if waking from deep sleep
    esp_sleep_wakeup_cause_t wakeup_reason = esp_sleep_get_wakeup_cause();
    if (wakeup_reason != ESP_SLEEP_WAKEUP_UNDEFINED) {
        handleWakeUp(wakeup_reason);
    }
    
    // Initialize sensors
    ldr.begin();
    touch.begin();
    if (!accel.begin()) {
        Serial.println("⚠️  Accelerometer failed!");
    }
    mic.begin();
    
    // Initialize outputs
    display.begin();
    buzzer.begin();
    
    // Show startup animation
    display.setEmotion(HAPPY);
    buzzer.startupSound();
    
    // Initialize WiFi
    wifiMgr.begin();
    
    // If WiFi connected, sync time
    if (wifiMgr.isConnected()) {
        configTime(GMT_OFFSET_SEC, DAYLIGHT_OFFSET_SEC, NTP_SERVER);
    }
    
    Serial.println("✓ Robot Ready!");
    lastInteractionTime = millis();
}
 
void loop() {
    // STEP 1: Update all sensors
    if (sensorTimer.isReady()) {
        ldr.update();
        touch.update();
        accel.update();
        
        // Pass movement info to touch for hold detection
        touch.setMovementDetected(accel.isMoving());
    }
    
    if (soundTimer.isReady()) {
        mic.update();
    }
    
    // STEP 2: Check priority events
    if (handlePriorityEvents()) {
        return;  // Priority event handled, skip normal processing
    }
    
    // STEP 3: Process sensor fusion and update state
    if (behaviorTimer.isReady()) {
        ContextData context = analyzeContext();
        EmotionState newEmotion = evaluateEmotion(context);
        
        if (newEmotion != currentEmotion && stateTransitionCooldown.elapsed() > STATE_TRANSITION_COOLDOWN) {
            transitionToState(newEmotion);
            stateTransitionCooldown.reset();
        }
        
        updateAutonomousBehaviors(context);
    }
    
    // STEP 4: Execute current state behavior
    executeStateBehavior();
    
    // STEP 5: Update outputs
    if (displayTimer.isReady()) {
        if (wifiMgr.isConnected() && millis() - lastInteractionTime > 120000) {
            display.showClock(true);
            display.updateClock();
        } else {
            display.showClock(false);
            display.update();
        }
    }
    
    buzzer.update();  // Continue playing melodies
    
    // STEP 6: WiFi tasks
    wifiMgr.update();
    
    // STEP 7: Check deep sleep
    if (shouldEnterDeepSleep && checkDeepSleepCriteria()) {
        enterDeepSleep();
    }
    
    delay(1);  // Stability delay
}
 
